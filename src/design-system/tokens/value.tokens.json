{
  "meta": {
    "name": "ViralCo UI System",
    "version": "2.0.0",
    "source": "Derived from Blazity next-saas-starter and adapted for ViralCo product UI",
    "notes": [
      "Primary action blue comes from the original starter Sign up CTA.",
      "Secondary accent yellow comes from the existing ViralCo frontend codebase.",
      "Spacing follows an 8px rhythm and grayscale follows a 0-9 progression."
    ]
  },
  "color": {
    "primitive": {
      "blue": {
        "50": "#edf4ff",
        "100": "#dbe9ff",
        "200": "#bdd6ff",
        "300": "#8eb8ff",
        "400": "#5f99ff",
        "500": "#1673ff",
        "600": "#0c5ee0",
        "700": "#0c4db4",
        "800": "#123c83",
        "900": "#122c5f"
      },
      "yellow": {
        "50": "#fff9e5",
        "100": "#fff1bf",
        "200": "#ffe693",
        "300": "#ffd85c",
        "400": "#ffbf00",
        "500": "#f0ab00",
        "600": "#c88800",
        "700": "#996400",
        "800": "#6b4500",
        "900": "#452b00"
      },
      "gray": {
        "0": "#ffffff",
        "1": "#f7f9fc",
        "2": "#e7edf5",
        "3": "#c9d3e1",
        "4": "#9aa8bd",
        "5": "#6c7a90",
        "6": "#49556a",
        "7": "#2d3748",
        "8": "#182131",
        "9": "#0b1320"
      },
      "cyan": {
        "100": "#d9fbff",
        "200": "#aef5ff",
        "300": "#51e7ff",
        "400": "#05c9ea",
        "500": "#008ca7",
        "600": "#006d82"
      },
      "rose": {
        "100": "#ffe2df",
        "200": "#ffbdb8",
        "500": "#cb3347",
        "700": "#9e1d30"
      }
    },
    "semantic": {
      "background": {
        "canvas": {
          "default": "{color.primitive.gray.9}",
          "subtle": "{color.primitive.gray.8}",
          "elevated": "{color.primitive.gray.7}",
          "sunken": "#070d18"
        }
      },
      "surface": {
        "panel": {
          "default": "rgba(24, 33, 49, 0.86)",
          "muted": "rgba(11, 19, 32, 0.92)",
          "elevated": "rgba(45, 55, 72, 0.94)",
          "overlay": "rgba(11, 19, 32, 0.7)"
        },
        "card": {
          "default": "rgba(24, 33, 49, 0.9)",
          "subtle": "rgba(16, 24, 38, 0.86)",
          "interactive": "rgba(29, 41, 61, 0.96)",
          "selected": "rgba(22, 115, 255, 0.18)"
        }
      },
      "text": {
        "primary": {
          "default": "{color.primitive.gray.0}",
          "hover": "{color.primitive.gray.1}",
          "inverse": "{color.primitive.gray.9}"
        },
        "secondary": {
          "default": "{color.primitive.gray.3}",
          "hover": "{color.primitive.gray.2}"
        },
        "muted": {
          "default": "{color.primitive.gray.4}",
          "hover": "{color.primitive.gray.3}"
        },
        "accent": {
          "default": "{color.primitive.yellow.200}",
          "hover": "{color.primitive.yellow.100}"
        },
        "info": {
          "default": "{color.primitive.cyan.200}"
        },
        "danger": {
          "default": "{color.primitive.rose.200}"
        }
      },
      "border": {
        "subtle": {
          "default": "rgba(151, 168, 191, 0.12)",
          "strong": "rgba(151, 168, 191, 0.24)"
        },
        "accent": {
          "default": "rgba(22, 115, 255, 0.32)",
          "focus": "rgba(22, 115, 255, 0.48)"
        },
        "warning": {
          "default": "rgba(255, 191, 0, 0.28)"
        },
        "danger": {
          "default": "rgba(255, 189, 184, 0.26)"
        }
      },
      "action": {
        "primary": {
          "default": "{color.primitive.blue.500}",
          "hover": "{color.primitive.blue.400}",
          "pressed": "{color.primitive.blue.600}",
          "disabled": "rgba(22, 115, 255, 0.28)",
          "text": "{color.primitive.gray.0}"
        },
        "secondary": {
          "default": "{color.primitive.yellow.400}",
          "hover": "{color.primitive.yellow.300}",
          "pressed": "{color.primitive.yellow.500}",
          "disabled": "rgba(255, 191, 0, 0.18)",
          "text": "{color.primitive.yellow.900}"
        },
        "tertiary": {
          "default": "transparent",
          "hover": "rgba(255, 255, 255, 0.06)",
          "pressed": "rgba(255, 255, 255, 0.1)",
          "disabled": "rgba(255, 255, 255, 0.03)",
          "text": "{color.primitive.gray.2}"
        },
        "danger": {
          "default": "{color.primitive.rose.500}",
          "hover": "#de4156",
          "pressed": "{color.primitive.rose.700}",
          "disabled": "rgba(203, 51, 71, 0.24)",
          "text": "{color.primitive.gray.0}"
        }
      },
      "feedback": {
        "info": {
          "default": "{color.primitive.cyan.300}",
          "surface": "rgba(81, 231, 255, 0.16)"
        },
        "success": {
          "default": "{color.primitive.cyan.200}",
          "surface": "rgba(174, 245, 255, 0.14)"
        },
        "warning": {
          "default": "{color.primitive.yellow.200}",
          "surface": "rgba(255, 230, 147, 0.14)"
        },
        "danger": {
          "default": "{color.primitive.rose.200}",
          "surface": "rgba(255, 189, 184, 0.16)"
        }
      },
      "focus": {
        "ring": {
          "default": "rgba(22, 115, 255, 0.34)"
        }
      }
    }
  },
  "text": {
    "family": {
      "display": "\"Sora\", \"Space Grotesk\", sans-serif",
      "body": "\"IBM Plex Sans\", \"Inter\", sans-serif",
      "mono": "\"IBM Plex Mono\", monospace"
    },
    "display": {
      "font-64/800/64": {
        "fontFamily": "{text.family.display}",
        "fontSize": 64,
        "fontWeight": 800,
        "lineHeight": 64,
        "letterSpacing": -3
      },
      "font-48/700/52": {
        "fontFamily": "{text.family.display}",
        "fontSize": 48,
        "fontWeight": 700,
        "lineHeight": 52,
        "letterSpacing": -2
      }
    },
    "heading": {
      "font-32/700/38": {
        "fontFamily": "{text.family.display}",
        "fontSize": 32,
        "fontWeight": 700,
        "lineHeight": 38,
        "letterSpacing": -1
      },
      "font-24/700/30": {
        "fontFamily": "{text.family.display}",
        "fontSize": 24,
        "fontWeight": 700,
        "lineHeight": 30,
        "letterSpacing": -0.5
      },
      "font-20/600/26": {
        "fontFamily": "{text.family.display}",
        "fontSize": 20,
        "fontWeight": 600,
        "lineHeight": 26,
        "letterSpacing": -0.2
      }
    },
    "body": {
      "font-18/500/28": {
        "fontFamily": "{text.family.body}",
        "fontSize": 18,
        "fontWeight": 500,
        "lineHeight": 28,
        "letterSpacing": 0
      },
      "font-16/500/24": {
        "fontFamily": "{text.family.body}",
        "fontSize": 16,
        "fontWeight": 500,
        "lineHeight": 24,
        "letterSpacing": 0
      },
      "font-14/500/20": {
        "fontFamily": "{text.family.body}",
        "fontSize": 14,
        "fontWeight": 500,
        "lineHeight": 20,
        "letterSpacing": 0
      },
      "font-14/400/20": {
        "fontFamily": "{text.family.body}",
        "fontSize": 14,
        "fontWeight": 400,
        "lineHeight": 20,
        "letterSpacing": 0
      },
      "font-12/500/16": {
        "fontFamily": "{text.family.body}",
        "fontSize": 12,
        "fontWeight": 500,
        "lineHeight": 16,
        "letterSpacing": 0
      }
    },
    "label": {
      "font-13/600/18": {
        "fontFamily": "{text.family.display}",
        "fontSize": 13,
        "fontWeight": 600,
        "lineHeight": 18,
        "letterSpacing": 1
      },
      "font-12/700/16": {
        "fontFamily": "{text.family.display}",
        "fontSize": 12,
        "fontWeight": 700,
        "lineHeight": 16,
        "letterSpacing": 1.2
      },
      "font-11/700/14": {
        "fontFamily": "{text.family.mono}",
        "fontSize": 11,
        "fontWeight": 700,
        "lineHeight": 14,
        "letterSpacing": 0.8
      }
    }
  },
  "space": {
    "0": 0,
    "8": 8,
    "16": 16,
    "24": 24,
    "32": 32,
    "40": 40,
    "48": 48,
    "56": 56,
    "64": 64,
    "72": 72,
    "80": 80,
    "96": 96,
    "120": 120
  },
  "radius": {
    "none": 0,
    "xs": 4,
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 24,
    "2xl": 32,
    "pill": 999
  },
  "elevation": {
    "surface": {
      "low": "0 3px 8px rgba(3, 9, 20, 0.07)",
      "mid": "0 4px 10px rgba(3, 9, 20, 0.072)",
      "high": "0 6px 11px rgba(3, 9, 20, 0.088)"
    },
    "glow": {
      "primary": "0 0 0 1px rgba(22, 115, 255, 0.2), 0 0 24px rgba(22, 115, 255, 0.18)",
      "secondary": "0 0 0 1px rgba(255, 191, 0, 0.22), 0 0 24px rgba(255, 191, 0, 0.18)",
      "info": "0 0 0 1px rgba(81, 231, 255, 0.2), 0 0 20px rgba(81, 231, 255, 0.16)"
    }
  },
  "motion": {
    "duration": {
      "fast": 120,
      "moderate": 180,
      "slow": 280
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0.8, 0.2, 1)",
      "entrance": "cubic-bezier(0.16, 1, 0.3, 1)"
    }
  }
}
